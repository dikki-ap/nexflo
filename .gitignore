# ──────────────────────────────────────────────
# NexFlo — .gitignore
# Flutter 3.29.x | Dart 3.7.x
# ──────────────────────────────────────────────

# ── Project Specific ───────────────────────────
plans/
.claude/

# ── Flutter / Dart ─────────────────────────────
# Dependencies
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# Build outputs
build/
.build/

# Dart generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Drift generated files
*.drift.dart

# pubspec lock (include this if library, exclude if app)
# pubspec.lock  ← untuk app sebaiknya di-COMMIT, jadi tidak di-exclude

# ── IDE & Editor ───────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws
.name

# ── Android ────────────────────────────────────
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
android/**/gradle-wrapper.jar
android/key.properties          # signing config — JANGAN di-commit
android/app/google-services.json  # Firebase/Google config — JANGAN di-commit

# ── iOS ────────────────────────────────────────
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
ios/Pods/
ios/.symlinks/
ios/GoogleService-Info.plist     # Google config — JANGAN di-commit

# CocoaPods
*.xcworkspace/xcshareddata/
!ios/Runner.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
**/Podfile.lock

# ── macOS ──────────────────────────────────────
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/
macos/Pods/
macos/.symlinks/

# ── Web ────────────────────────────────────────
lib/generated_plugin_registrant.dart

# ── Windows ────────────────────────────────────
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# ── Linux ──────────────────────────────────────
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

